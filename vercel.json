{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "flipledger.vercel.app" }],
      "destination": "https://flipledgerhq.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/sync-and-delist",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    },
    "api/cron/*.js": {
      "maxDuration": 120
    }
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
